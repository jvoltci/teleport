# Domain Caddy will provision a TLS cert for
DOMAIN=signal.yourdomain.com

# Email registered with Let's Encrypt for cert renewal notices
ACME_EMAIL=admin@yourdomain.com

# CORS — set to the URL of your deployed frontend
# (comma-separated for multiple)
CORS_ORIGINS=https://your-username.github.io

# How long an inactive room is kept before cleanup (seconds)
ROOM_TTL_SECONDS=60

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
