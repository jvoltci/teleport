# Required: WebSocket URL of your signaling server
# Local dev: ws://localhost:4000
# Production: wss://signal.yourdomain.com
NEXT_PUBLIC_SIGNALING_URL=ws://localhost:4000

# Optional: comma-separated STUN URLs (defaults to Google public STUN)
# NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# Optional: TURN server for users behind symmetric NAT
# NEXT_PUBLIC_TURN_URL=turn:turn.yourdomain.com:3478
# NEXT_PUBLIC_TURN_USERNAME=user
# NEXT_PUBLIC_TURN_CREDENTIAL=pass

# Optional: set if hosting under a subpath (e.g. username.github.io/teleport)
# NEXT_PUBLIC_BASE_PATH=/teleport

# Optional: canonical site URL for OpenGraph
# NEXT_PUBLIC_SITE_URL=https://teleport.yourdomain.com
